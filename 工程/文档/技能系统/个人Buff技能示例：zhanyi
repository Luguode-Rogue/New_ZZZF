## 代码实现详解

### 步骤1：技能类（ZhanYi.cs）

```csharp
public class ZhanYi : SkillBase
{
    public ZhanYi()
    {
        SkillID = "ZhanYi";
        Type = SPSkillType.MainActive;
        Cooldown = 60f;
        ResourceCost = 0f;
    }

    public override void Activate(Agent agent)
    {
        var component = agent.GetComponent<AgentSkillComponent>();
        if (component == null) return;

        // 创建Buff实例并添加到状态容器
        var buff = new ZhanYiBuff(8f, agent);
        component.StateContainer.AddState(buff);

        // 播放特效和提示
        MBInformationManager.AddQuickInformation(
            new TaleWorlds.Localization.TextObject($"{agent.Name} 进入了战意状态！"), 
            50, null, "");
    }

    public override bool CheckCondition(Agent caster)
    {
        // AI触发条件：血量低于50% 或 周围有5个以上敌人
        var component = caster.GetComponent<AgentSkillComponent>();
        if (component == null) return false;

        if (caster.Health / component.MaxHP <= 0.5f) return true;

        List<Agent> enemies = Script.GetTargetedInRange(caster, caster.GetEyeGlobalPosition(), 30);
        return enemies.Count > 5;
    }
}
```

### 步骤2：Buff类（ZhanYiBuff.cs）

```csharp
public class ZhanYiBuff : AgentBuff
{
    private Agent _caster;
    private float _timeSinceLastTick;

    public ZhanYiBuff(float duration, Agent caster) : base(duration)
    {
        StateId = "ZhanYiBuff";
        _caster = caster;
        _timeSinceLastTick = 0f;
    }

    public override void OnApply(Agent agent)
    {
        // Buff生效时，触发一次属性更新
        agent.UpdateAgentProperties();
        
        // 添加视觉效果
        Script.spawnParticleEffect(agent.Position, "psys_weapon_lightning_emit");
    }

    public override void OnUpdate(Agent agent, float dt)
    {
        // 1. 每秒回复5耐力
        _timeSinceLastTick += dt;
        if (_timeSinceLastTick >= 1f)
        {
            var component = agent.GetComponent<AgentSkillComponent>();
            if (component != null)
            {
                component.Mana = Math.Min(component.Mana + 5f, 100f); // 用Mana字段存储耐力
            }
            _timeSinceLastTick -= 1f;
        }

        // 2. 触发属性更新（速度和伤害加成）
        agent.UpdateAgentProperties();

        // 3. 检测击杀（通过SkillSystemBehavior的命中事件）
        // 这部分在SkillSystemBehavior.ExecuteHitEvents()中处理
    }

    public override void OnRemove(Agent agent)
    {
        // Buff移除时，再触发一次属性更新，清除加成
        agent.UpdateAgentProperties();
        
        // 移除特效
        Script.removeParticleEffect(agent, "psys_weapon_lightning_emit");
    }

    // 击杀触发的方法（由SkillSystemBehavior调用）
    public void OnKillAgent(Agent killedAgent)
    {
        if (_caster == null || _caster.IsDeleted) return;

        // 恢复50%已损失血量
        var component = _caster.GetComponent<AgentSkillComponent>();
        if (component != null)
        {
            float healthLost = component.MaxHP - _caster.Health;
            float healAmount = healthLost * 0.5f;
            _caster.Health = Math.Min(_caster.Health + healAmount, component.MaxHP);
        }

        // 重置持续时间为8秒，如果已经超过8秒则加1秒
        if (RemainingTime > 8f)
        {
            RemainingTime += 1f;
        }
        else
        {
            RemainingTime = 8f;
        }
    }
}
```

### 步骤3：属性计算类（ZZZF_SandboxAgentStatCalculateModel.cs）

```csharp
public class ZZZF_SandboxAgentStatCalculateModel : SandboxAgentStatCalculateModel
{
    public override void UpdateAgentStats(Agent agent, AgentDrivenProperties agentDrivenProperties)
    {
        base.UpdateAgentStats(agent, agentDrivenProperties);

        // 检查Agent是否有战意Buff
        var component = agent.GetComponent<AgentSkillComponent>();
        if (component == null) return;

        // 如果没有战意Buff，直接返回（不修改属性）
        if (!component.StateContainer.HasState("ZhanYiBuff")) return;

        // 有战意Buff，根据耐力值增加速度和伤害
        float stamina = component.Mana; // 用Mana字段存储耐力
        
        // 增加移动速度（CombatMaxSpeedMultiplier）
        float speedBonus = stamina / 100f; // 耐力值 = 速度加成
        agentDrivenProperties.CombatMaxSpeedMultiplier *= (1f + speedBonus);

        // 增加近战武器速度（SwingSpeedMultiplier）
        float swingSpeedBonus = stamina / 100f;
        agentDrivenProperties.SwingSpeedMultiplier *= (1f + swingSpeedBonus);
    }

    // 伤害加成在伤害计算模型中实现
    public override float GetWeaponDamageMultiplier(Agent attacker, WeaponComponentData weapon)
    {
        float multiplier = base.GetWeaponDamageMultiplier(attacker, weapon);

        var component = attacker.GetComponent<AgentSkillComponent>();
        if (component == null) return multiplier;

        // 如果有战意Buff，根据耐力值增加伤害
        if (component.StateContainer.HasState("ZhanYiBuff"))
        {
            float stamina = component.Mana;
            float damageBonus = stamina / 100f; // 耐力值 = 伤害加成
            multiplier *= (1f + damageBonus);
        }

        return multiplier;
    }
}
```

### 步骤4：击杀检测（SkillSystemBehavior.cs）

```csharp
public class SkillSystemBehavior : MissionLogic
{
    private void ExecuteHitEvents(Agent attacker, Agent victim, bool isCanceled, AttackCollisionData collisionData)
    {
        // 检测受害者是否死亡
        if (victim == null || victim.State == AgentState.Killed)
        {
            // 攻击者是否有战意Buff
            var component = attacker.GetComponent<AgentSkillComponent>();
            if (component != null && component.StateContainer.HasState("ZhanYiBuff"))
            {
                // 获取战意Buff实例并调用OnKillAgent方法
                var zhanYiBuff = component.StateContainer.GetState("ZhanYiBuff") as ZhanYiBuff;
                zhanYiBuff?.OnKillAgent(victim);
            }
        }

        // 其他命中事件处理...
    }
}
```

