## 代码实现详解

### 步骤1：技能类（WeiYa.cs）

```csharp
public class WeiYa : SkillBase
{
    public WeiYa()
    {
        SkillID = "WeiYa";
        Type = SPSkillType.MainActive;
        Cooldown = 60f;
        ResourceCost = 0f;
    }

    public override void Activate(Agent agent)
    {
        var component = agent.GetComponent<AgentSkillComponent>();
        if (component == null) return;

        // 给施法者添加自身Buff（光环控制器）
        var buff = new WeiYaBuff(8f, agent);
        component.StateContainer.AddState(buff);

        // 播放特效和音效
        Script.SpawnParticleEffect(agent.Position, "psys_weapon_lightning_emit");
        MBInformationManager.AddQuickInformation(
            new TaleWorlds.Localization.TextObject($"{agent.Name} 释放了威压！"), 
            50, null, "");
    }

    public override bool CheckCondition(Agent caster)
    {
        // AI触发条件：周围有敌人
        List<Agent> enemies = Script.GetTargetedInRange(caster, caster.GetEyeGlobalPosition(), 10);
        return enemies.Count > 0;
    }
}
```

### 步骤2：自身Buff类（WeiYaBuff.cs）

```csharp
public class WeiYaBuff : AgentBuff
{
    private Agent _caster;
    private List<Agent> _affectedAgents = new List<Agent>();

    public WeiYaBuff(float duration, Agent caster)
    {
        StateId = "WeiYaBuff";
        Duration = duration;
        _caster = caster;
    }

    public override void OnApply(Agent agent)
    {
        // 施法者身上添加光环特效
        agent.PlayParticleEffect("psys_aura_pressure");
    }

    public override void OnUpdate(Agent agent, float dt)
    {
        if (_caster == null || _caster.IsDeleted) return;

        // 获取范围内所有敌人
        List<Agent> enemiesInRange = Script.GetTargetedInRange(
            _caster, 
            _caster.GetEyeGlobalPosition(), 
            30f);

        // 给新进入范围的敌人添加Debuff
        foreach (Agent enemy in enemiesInRange)
        {
            if (!_affectedAgents.Contains(enemy))
            {
                var debuff = new WeiYaDebuff(8f, _caster);
                enemy.GetComponent<AgentSkillComponent>()?.StateContainer.AddState(debuff);
                _affectedAgents.Add(enemy);
            }
        }

        // 移除离开范围的敌人的Debuff
        for (int i = _affectedAgents.Count - 1; i >= 0; i--)
        {
            Agent affectedAgent = _affectedAgents[i];
            if (affectedAgent == null || affectedAgent.IsDeleted ||
                !enemiesInRange.Contains(affectedAgent))
            {
                affectedAgent?.GetComponent<AgentSkillComponent>()?
                    .StateContainer.RemoveState("WeiYaDebuff");
                _affectedAgents.RemoveAt(i);
            }
        }
    }

    public override void OnRemove(Agent agent)
    {
        // 移除所有受影响敌人的Debuff
        foreach (Agent affectedAgent in _affectedAgents)
        {
            affectedAgent?.GetComponent<AgentSkillComponent>()?
                .StateContainer.RemoveState("WeiYaDebuff");
        }
        _affectedAgents.Clear();

        // 停止特效
        agent.StopParticleEffect("psys_aura_pressure");
    }
}
```

### 步骤3：目标Debuff类（WeiYaDebuff.cs）

```csharp
public class WeiYaDebuff : AgentBuff
{
    private Agent _sourceAgent;

    public WeiYaDebuff(float duration, Agent sourceAgent)
    {
        StateId = "WeiYaDebuff";
        Duration = duration;
        _sourceAgent = sourceAgent;
    }

    public override void OnApply(Agent agent)
    {
        // 目标身上添加受影响的视觉效果
        agent.PlayParticleEffect("psys_debuff_pressure");
        
        // 可以在这里添加文字提示
        MBInformationManager.AddQuickInformation(
            new TaleWorlds.Localization.TextObject($"{agent.Name} 受到了威压影响！"), 
            30, null, "");
    }

    public override void OnRemove(Agent agent)
    {
        // 移除特效
        agent.StopParticleEffect("psys_debuff_pressure");
    }
}
```

### 步骤4：伤害修正逻辑

在伤害计算模型中，根据目标是否有 `WeiYaDebuff` 来修正伤害：

```csharp
// 文件：WOW_SandboxAgentStatCalculateModel.cs
public override float GetWeaponDamageMultiplier(Agent attacker, WeaponComponentData weapon)
{
    float multiplier = 1f;

    // 检查攻击者是否有威压Debuff
    var component = attacker.GetComponent<AgentSkillComponent>();
    if (component != null && component.StateContainer.HasState("WeiYaDebuff"))
    {
        multiplier *= 0.75f; // 伤害降低25%
    }

    return multiplier;
}
```

